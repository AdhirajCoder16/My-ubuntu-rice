configuration {
  modi: "drun,run,window";
  show-icons: true;
  icon-theme: "Papirus";
  font: "JetBrains Mono Nerd Font 12";
  drun-display-format: "{name}";
}

window {
  width: 40%;
  border: 2px;
  border-color: #cba6f7;
  border-radius: 12px;
}

entry {
  placeholder: "  Search apps...";
  placeholder-color: #6c7086;
}
