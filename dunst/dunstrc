[global]
monitor = 0
follow = mouse
width = 320
height = 100
origin = top-right
offset = 12x48
gap_size = 6
font = JetBrains Mono Nerd Font 10
line_height = 4
corner_radius = 8
frame_width = 2
frame_color = #cba6f7

[urgency_low]
background = #1e1e2e
foreground = #cdd6f4
timeout = 5

[urgency_normal]
background = #313244
foreground = #cdd6f4
frame_color = #89b4fa
timeout = 8

[urgency_critical]
background = #f38ba8
foreground = #1e1e2e
frame_color = #f38ba8
timeout = 0


